# Backend (MySQL) - use apenas no servidor, nunca no frontend
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Servidor API
PORT=3535

# Estoque: setores permitidos na query de saldo
# Use apenas números separados por vírgula (ex.: 5,24)
STOCK_SECTOR_IDS=5,24

# Frontend (Vite) - prefixo VITE_ expõe ao bundle
VITE_API_URL=http://localhost:3535
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

